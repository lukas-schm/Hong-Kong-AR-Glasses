{
  "name": "cdars-glasses-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "qr": "node scripts/qr.mjs",
    "pack": "npx -y @evenrealities/evenhub-cli pack app.json dist -o cdars-cdss.ehpk",
    "simulate": "npx -y @evenrealities/evenhub-simulator http://localhost:5173"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "qrcode-terminal": "^0.12.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
